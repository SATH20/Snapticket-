# 🌐 Database
# Get from: https://www.mongodb.com/cloud/atlas/register
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/?appName=YourApp

# 🔐 Clerk Authentication
# Get from: https://dashboard.clerk.com → Your App → API Keys
CLERK_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
CLERK_SECRET_KEY=sk_test_your_secret_key_here

# ⚙️ Inngest Event Scheduling (Optional)
# Get from: https://www.inngest.com
INNGEST_EVENT_KEY=your_inngest_event_key_here
INNGEST_SIGNING_KEY=your_inngest_signing_key_here

# 🎬 TMDB API (for movie data)
# Get from: https://www.themoviedb.org/settings/api
TMDB_API_KEY=your_tmdb_api_key_or_bearer_token_here

# 💳 Stripe Payment Integration
# Get from: https://dashboard.stripe.com/test/apikeys
STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key_here
STRIPE_SECRET_KEY=sk_test_your_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# 📧 Email Notifications (Optional)
SENDER_EMAIL=your-sender@example.com
SMTP_USER=your_smtp_username
SMTP_PASS=your_smtp_password
